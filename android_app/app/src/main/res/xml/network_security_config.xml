<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 개발 환경: 모든 cleartext HTTP 허용 (테스트용) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 명시적 도메인 설정 -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android 에뮬레이터에서 호스트 PC의 localhost 접근 -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- 실제 기기에서 localhost 접근 -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- 로컬 네트워크 IP (개발용) - 명시적 IP 주소 -->
        <domain includeSubdomains="true">192.168.0.40</domain>
        <domain includeSubdomains="true">192.168.0.51</domain>
        <domain includeSubdomains="true">192.168.0.100</domain>
        <domain includeSubdomains="true">192.168.0.101</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
    </domain-config>
</network-security-config>
